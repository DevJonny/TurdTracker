@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IThemeService ThemeService
@inject ISyncService SyncService
@inject ISnackbar Snackbar
@implements IDisposable

<MudThemeProvider Theme="_theme" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" Class="desktop-only" />
        <MudText Typo="Typo.h6">TurdTracker</MudText>
        <MudSpacer />
        <MudTooltip Text="@GetSyncTooltip()">
            <MudIconButton Icon="@GetSyncIcon()" Color="@GetSyncColor()" OnClick="@OnSyncIconClick" />
        </MudTooltip>
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="@ToggleTheme" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Class="desktop-only">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">TurdTracker</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.MenuBook">Diary</MudNavLink>
            <MudNavLink Href="calendar" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CalendarMonth">Calendar</MudNavLink>
            <MudNavLink Href="stats" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.BarChart">Stats</MudNavLink>
            <MudNavLink Href="settings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="main-content">
        @Body
    </MudMainContent>

    <div class="bottom-nav mobile-only">
        <MudToolBar Dense="true" Class="justify-center">
            <MudIconButton Icon="@Icons.Material.Filled.MenuBook" Color="@GetNavColor("/")" OnClick="@(() => Navigation.NavigateTo(""))" />
            <MudIconButton Icon="@Icons.Material.Filled.CalendarMonth" Color="@GetNavColor("/calendar")" OnClick="@(() => Navigation.NavigateTo("calendar"))" />
            <MudIconButton Icon="@Icons.Material.Filled.BarChart" Color="@GetNavColor("/stats")" OnClick="@(() => Navigation.NavigateTo("stats"))" />
            <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="@GetNavColor("/settings")" OnClick="@(() => Navigation.NavigateTo("settings"))" />
        </MudToolBar>
    </div>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;

    private MudTheme _theme = new MudTheme
    {
        PaletteDark = new PaletteDark
        {
            Black = "#1a1a1a",
            Background = "#2d2d2d",
            Surface = "#363636",
            AppbarBackground = "#2d2d2d",
            DrawerBackground = "#2d2d2d",
            Primary = "#7c4dff",
            Secondary = "#03dac6",
            Tertiary = "#bb86fc",
            TextPrimary = "#e0e0e0",
            TextSecondary = "#a0a0a0",
            ActionDefault = "#b0b0b0",
            DrawerText = "#e0e0e0",
            DrawerIcon = "#a0a0a0",
            AppbarText = "#e0e0e0",
        },
        PaletteLight = new PaletteLight
        {
            Primary = "#5e35b1",
            Secondary = "#00897b",
            Tertiary = "#7c4dff",
            AppbarBackground = "#5e35b1",
            AppbarText = "#ffffff",
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await ThemeService.GetIsDarkModeAsync();
            SyncService.OnSyncStatusChanged += OnSyncStatusChanged;
            await SyncService.InitializeAsync();
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        await ThemeService.SetIsDarkModeAsync(_isDarkMode);
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void OnSyncStatusChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private string GetSyncIcon() => SyncService.SyncStatus switch
    {
        SyncStatus.Synced => Icons.Material.Filled.CloudDone,
        SyncStatus.Syncing => Icons.Material.Filled.CloudSync,
        SyncStatus.Error => Icons.Material.Filled.CloudOff,
        SyncStatus.NotSignedIn => Icons.Material.Filled.CloudOff,
        SyncStatus.Idle => Icons.Material.Filled.CloudDone,
        _ => Icons.Material.Filled.CloudOff
    };

    private Color GetSyncColor() => SyncService.SyncStatus switch
    {
        SyncStatus.Synced => Color.Success,
        SyncStatus.Syncing => Color.Inherit,
        SyncStatus.Error => Color.Error,
        SyncStatus.NotSignedIn => Color.Default,
        SyncStatus.Idle => Color.Success,
        _ => Color.Default
    };

    private string GetSyncTooltip()
    {
        var status = SyncService.SyncStatus switch
        {
            SyncStatus.Synced => "Synced",
            SyncStatus.Syncing => "Syncing...",
            SyncStatus.Error => "Sync error",
            SyncStatus.NotSignedIn => "Not signed in",
            SyncStatus.Idle => "Synced",
            _ => "Unknown"
        };

        if (SyncService.LastSyncedUtc.HasValue)
        {
            return $"{status} — Last synced: {SyncService.LastSyncedUtc.Value.ToLocalTime():g}";
        }

        return $"{status} — Not synced yet";
    }

    private void OnSyncIconClick()
    {
        if (SyncService.SyncStatus == SyncStatus.Error)
        {
            Snackbar.Add("Sync failed. Check your connection and try again from Settings.", Severity.Error);
        }
    }

    public void Dispose()
    {
        SyncService.OnSyncStatusChanged -= OnSyncStatusChanged;
    }

    private Color GetNavColor(string href)
    {
        var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
        var path = "/" + uri;

        if (href == "/")
        {
            return (path == "/" || path == "") ? Color.Primary : Color.Inherit;
        }

        return path.StartsWith(href) ? Color.Primary : Color.Inherit;
    }
}
