@page "/stats"
@using TurdTracker.Models
@using MudBlazor.Charts
@inject IDiaryService DiaryService
@inject ISyncService SyncService
@implements IDisposable

<PageTitle>Stats</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-4">
    <MudText Typo="Typo.h4" Class="mb-4">Stats</MudText>

    <MudText Typo="Typo.h6" Class="mb-2">Frequency Over Time</MudText>

    <MudChipSet T="string" SelectionMode="SelectionMode.SingleSelection" SelectedValue="@_selectedRange" SelectedValueChanged="OnRangeChanged" Class="mb-4">
        <MudChip T="string" Value="@("7")">Last 7 days</MudChip>
        <MudChip T="string" Value="@("30")">Last 30 days</MudChip>
        <MudChip T="string" Value="@("90")">Last 90 days</MudChip>
    </MudChipSet>

    @if (_frequencyData.Length == 0)
    {
        <MudText Color="Color.Secondary" Class="mb-4">No entries in the selected range.</MudText>
    }
    else
    {
        <MudChart T="double"
                  ChartType="ChartType.Bar"
                  ChartSeries="@_frequencySeries"
                  ChartLabels="@_frequencyLabels"
                  Width="100%"
                  Height="300px"
                  ChartOptions="@_chartOptions" Class="mb-4" />
    }

    <MudDivider Class="my-4" />

    <MudText Typo="Typo.h6" Class="mb-2">Bristol Type Distribution</MudText>

    @if (_bristolData.All(d => d == 0))
    {
        <MudText Color="Color.Secondary" Class="mb-4">No entries to display.</MudText>
    }
    else
    {
        <MudChart T="double"
                  ChartType="ChartType.Bar"
                  ChartSeries="@_bristolSeries"
                  ChartLabels="@_bristolLabels"
                  Width="100%"
                  Height="300px"
                  ChartOptions="@_bristolChartOptions" Class="mb-4" />
    }

    <MudDivider Class="my-4" />

    <MudText Typo="Typo.h6" Class="mb-2">Time of Day Patterns</MudText>

    @if (_timeOfDayData.All(d => d == 0))
    {
        <MudText Color="Color.Secondary" Class="mb-4">No entries to display.</MudText>
    }
    else
    {
        <MudChart T="double"
                  ChartType="ChartType.Bar"
                  ChartSeries="@_timeOfDaySeries"
                  ChartLabels="@_timeOfDayLabels"
                  Width="100%"
                  Height="300px"
                  ChartOptions="@_timeOfDayChartOptions" Class="mb-4" />
    }
</MudContainer>

@code {
    private List<DiaryEntry> _entries = [];
    private string _selectedRange = "7";
    private double[] _frequencyData = [];
    private string[] _frequencyLabels = [];
    private List<ChartSeries<double>> _frequencySeries = [];
    private BarChartOptions _chartOptions = new() { YAxisTicks = 1 };

    private double[] _bristolData = new double[7];
    private string[] _bristolLabels = ["Type 1", "Type 2", "Type 3", "Type 4", "Type 5", "Type 6", "Type 7"];
    private List<ChartSeries<double>> _bristolSeries = [];
    private BarChartOptions _bristolChartOptions = new() { YAxisTicks = 1 };

    private double[] _timeOfDayData = new double[24];
    private string[] _timeOfDayLabels = Enumerable.Range(0, 24).Select(h => h % 3 == 0 ? $"{h:D2}:00" : "").ToArray();
    private List<ChartSeries<double>> _timeOfDaySeries = [];
    private BarChartOptions _timeOfDayChartOptions = new() { YAxisTicks = 1 };

    protected override async Task OnInitializedAsync()
    {
        SyncService.OnDataMerged += OnDataMerged;
        _entries = await DiaryService.GetAllAsync();
        BuildFrequencyChart();
        BuildBristolDistribution();
        BuildTimeOfDayChart();
    }

    private async void OnDataMerged()
    {
        _entries = await DiaryService.GetAllAsync();
        BuildFrequencyChart();
        BuildBristolDistribution();
        BuildTimeOfDayChart();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SyncService.OnDataMerged -= OnDataMerged;
    }

    private void BuildBristolDistribution()
    {
        _bristolData = new double[7];
        foreach (var entry in _entries)
        {
            if (entry.BristolType >= 1 && entry.BristolType <= 7)
            {
                _bristolData[entry.BristolType - 1]++;
            }
        }

        _bristolSeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double> { Name = "Count", Data = _bristolData }
        };
    }

    private void BuildTimeOfDayChart()
    {
        _timeOfDayData = new double[24];
        foreach (var entry in _entries)
        {
            _timeOfDayData[entry.Timestamp.Hour]++;
        }

        _timeOfDaySeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double> { Name = "Entries", Data = _timeOfDayData }
        };
    }

    private void OnRangeChanged(string value)
    {
        if (string.IsNullOrEmpty(value)) return;
        _selectedRange = value;
        BuildFrequencyChart();
    }

    private void BuildFrequencyChart()
    {
        var days = int.Parse(_selectedRange);
        var today = DateTime.Today;
        var startDate = today.AddDays(-(days - 1));

        var entriesByDate = _entries
            .Where(e => e.Timestamp.Date >= startDate && e.Timestamp.Date <= today)
            .GroupBy(e => e.Timestamp.Date)
            .ToDictionary(g => g.Key, g => g.Count());

        if (days <= 7)
        {
            _frequencyData = new double[days];
            _frequencyLabels = new string[days];
            for (int i = 0; i < days; i++)
            {
                var date = startDate.AddDays(i);
                _frequencyLabels[i] = date.ToString("dd/MM");
                _frequencyData[i] = entriesByDate.GetValueOrDefault(date, 0);
            }
        }
        else if (days <= 30)
        {
            _frequencyData = new double[days];
            _frequencyLabels = new string[days];
            for (int i = 0; i < days; i++)
            {
                var date = startDate.AddDays(i);
                _frequencyLabels[i] = i % 5 == 0 ? date.ToString("dd/MM") : "";
                _frequencyData[i] = entriesByDate.GetValueOrDefault(date, 0);
            }
        }
        else
        {
            var weeks = (int)Math.Ceiling(days / 7.0);
            _frequencyData = new double[weeks];
            _frequencyLabels = new string[weeks];
            for (int w = 0; w < weeks; w++)
            {
                var weekStart = startDate.AddDays(w * 7);
                var weekEnd = weekStart.AddDays(6);
                if (weekEnd > today) weekEnd = today;

                _frequencyLabels[w] = weekStart.ToString("dd/MM");
                double count = 0;
                for (var d = weekStart; d <= weekEnd; d = d.AddDays(1))
                {
                    count += entriesByDate.GetValueOrDefault(d, 0);
                }
                _frequencyData[w] = count;
            }
        }

        _frequencySeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double> { Name = "Entries", Data = _frequencyData }
        };
    }
}
