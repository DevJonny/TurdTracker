@page "/"
@using Blazored.LocalStorage
@using TurdTracker.Models
@using TurdTracker.Services
@inject IDiaryService DiaryService
@inject NavigationManager Navigation
@inject IGoogleAuthService GoogleAuthService
@inject ISyncService SyncService
@inject ILocalStorageService LocalStorage
@implements IDisposable

<PageTitle>Diary</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-4">
    @if (_showBanner)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@DismissBanner">
            <div class="d-flex align-center justify-space-between flex-wrap gap-2">
                <MudText>Sync your diary across devices with Google Drive</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Cloud"
                           OnClick="@OnConnectClick">
                    Connect Google Drive
                </MudButton>
            </div>
        </MudAlert>
    }

    <MudText Typo="Typo.h4" Class="mb-4">Diary</MudText>

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" Class="d-block mx-auto my-8" />
    }
    else if (_entries.Count == 0)
    {
        <MudPaper Class="pa-8 text-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Class="mt-4">No entries yet</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Start tracking by logging your first entry.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => Navigation.NavigateTo("log"))">
                Log Entry
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudStack Spacing="2">
            @foreach (var entry in _entries)
            {
                <MudPaper Class="pa-3 cursor-pointer" Elevation="2" @onclick="@(() => Navigation.NavigateTo($"entry/{entry.Id}"))">
                    <div class="d-flex align-center justify-space-between">
                        <div class="d-flex align-center">
                            <MudAvatar Color="Color.Primary" Size="Size.Medium" Class="mr-3">@entry.BristolType</MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle1">@entry.Timestamp.ToString("ddd, d MMM yyyy — h:mm tt")</MudText>
                                @if (!string.IsNullOrWhiteSpace(entry.Notes))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@Truncate(entry.Notes, 80)</MudText>
                                }
                            </div>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Secondary" />
                    </div>
                    @if (entry.Tags.Count > 0)
                    {
                        <div class="d-flex flex-wrap gap-1 mt-2 ml-13">
                            @foreach (var tag in entry.Tags)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@tag</MudChip>
                            }
                        </div>
                    }
                </MudPaper>
            }
        </MudStack>
    }
</MudContainer>

<MudFab Style="position: fixed; bottom: 80px; right: 24px;"
        Color="Color.Primary"
        StartIcon="@Icons.Material.Filled.Add"
        OnClick="@(() => Navigation.NavigateTo("log"))" />

@code {
    private const string BannerDismissedKey = "sync-banner-dismissed";
    private List<DiaryEntry> _entries = [];
    private bool _loading = true;
    private bool _showBanner;

    protected override async Task OnInitializedAsync()
    {
        SyncService.OnDataMerged += OnDataMerged;
        var all = await DiaryService.GetAllAsync();
        _entries = all.OrderByDescending(e => e.Timestamp).ToList();
        _loading = false;
    }

    private void OnDataMerged()
    {
        _ = HandleDataMergedAsync();
    }

    private async Task HandleDataMergedAsync()
    {
        try
        {
            var all = await DiaryService.GetAllAsync();
            _entries = all.OrderByDescending(e => e.Timestamp).ToList();
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    public void Dispose()
    {
        SyncService.OnDataMerged -= OnDataMerged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var hasPreviousSession = await GoogleAuthService.HasPreviousSessionAsync();
            var isDismissed = await LocalStorage.GetItemAsync<bool>(BannerDismissedKey);
            _showBanner = !hasPreviousSession && !isDismissed;
            StateHasChanged();
        }
    }

    private async Task OnConnectClick()
    {
        var token = await GoogleAuthService.SignInAsync();
        if (token != null)
        {
            _showBanner = false;
            await SyncService.SyncAsync();
        }
    }

    private async Task DismissBanner()
    {
        _showBanner = false;
        await LocalStorage.SetItemAsync(BannerDismissedKey, true);
    }

    private static string Truncate(string text, int maxLength)
    {
        return text.Length <= maxLength ? text : text[..maxLength] + "…";
    }
}
