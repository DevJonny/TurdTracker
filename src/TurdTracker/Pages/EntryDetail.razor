@page "/entry/{Id:guid}"
@using TurdTracker.Models
@using TurdTracker.Services
@inject IDiaryService DiaryService
@inject NavigationManager Navigation
@inject IDialogService DialogService

<PageTitle>Entry Detail</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-4">
    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" Class="d-block mx-auto my-8" />
    }
    else if (_entry == null)
    {
        <MudPaper Class="pa-8 text-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Large" Color="Color.Error" />
            <MudText Typo="Typo.h6" Class="mt-4">Entry not found</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="@(() => Navigation.NavigateTo(""))">
                Back to Diary
            </MudButton>
        </MudPaper>
    }
    else if (_editing)
    {
        <div class="d-flex align-center justify-space-between mb-4">
            <MudText Typo="Typo.h4">Edit Entry</MudText>
        </div>

        <MudPaper Class="pa-4" Elevation="2">
            <MudGrid Spacing="3">
                <MudItem xs="6">
                    <MudDatePicker Label="Date" @bind-Date="_date" Required="true" />
                </MudItem>
                <MudItem xs="6">
                    <MudTimePicker Label="Time" @bind-Time="_time" Required="true" />
                </MudItem>
            </MudGrid>

            <div class="mt-4">
                <BristolScaleSelector @bind-SelectedType="_bristolType" />
            </div>

            <MudTextField T="string" Label="Notes (optional)" @bind-Value="_notes" Lines="3" Class="mt-4" Variant="Variant.Outlined" />

            <div class="mt-4">
                <TagInput @bind-Tags="_tags" />
            </div>

            <div class="d-flex justify-end mt-4">
                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CancelEdit" Class="mr-2">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEdit">Save</MudButton>
            </div>
        </MudPaper>
    }
    else
    {
        <div class="d-flex align-center justify-space-between mb-4">
            <MudText Typo="Typo.h4">Entry Detail</MudText>
            <div>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="StartEdit" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="ConfirmDelete" />
            </div>
        </div>

        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Spacing="3">
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Date & Time</MudText>
                    <MudText Typo="Typo.body1">@_entry.Timestamp.ToString("dddd, d MMMM yyyy — h:mm tt")</MudText>
                </div>

                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Bristol Stool Type</MudText>
                    <div class="d-flex align-center mt-1">
                        <MudAvatar Color="Color.Primary" Size="Size.Medium" Class="mr-3">@_entry.BristolType</MudAvatar>
                        <MudText Typo="Typo.body1">Type @_entry.BristolType</MudText>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_entry.Notes))
                {
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Notes</MudText>
                        <MudText Typo="Typo.body1">@_entry.Notes</MudText>
                    </div>
                }

                @if (_entry.Tags.Count > 0)
                {
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Tags</MudText>
                        <div class="d-flex flex-wrap gap-1 mt-1">
                            @foreach (var tag in _entry.Tags)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@tag</MudChip>
                            }
                        </div>
                    </div>
                }
            </MudStack>
        </MudPaper>

        <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mt-4" OnClick="@(() => Navigation.NavigateTo(""))">
            Back to Diary
        </MudButton>
    }
</MudContainer>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private DiaryEntry? _entry;
    private bool _loading = true;
    private bool _editing;

    private DateTime? _date;
    private TimeSpan? _time;
    private int _bristolType;
    private string _notes = string.Empty;
    private List<string> _tags = [];

    protected override async Task OnInitializedAsync()
    {
        _entry = await DiaryService.GetByIdAsync(Id);
        _loading = false;
    }

    private void StartEdit()
    {
        if (_entry == null) return;
        _date = _entry.Timestamp.Date;
        _time = _entry.Timestamp.TimeOfDay;
        _bristolType = _entry.BristolType;
        _notes = _entry.Notes;
        _tags = new List<string>(_entry.Tags);
        _editing = true;
    }

    private void CancelEdit()
    {
        _editing = false;
    }

    private async Task SaveEdit()
    {
        if (_entry == null || _bristolType == 0 || _date == null || _time == null)
            return;

        _entry.Timestamp = _date.Value.Date + _time.Value;
        _entry.BristolType = _bristolType;
        _entry.Notes = _notes;
        _entry.Tags = _tags;

        await DiaryService.UpdateAsync(_entry);
        _editing = false;
    }

    private async Task ConfirmDelete()
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "Delete Entry",
            "Are you sure you want to delete this entry? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            await DiaryService.DeleteAsync(Id);
            Navigation.NavigateTo("");
        }
    }
}
